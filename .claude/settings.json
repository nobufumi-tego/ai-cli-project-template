{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ruff check --fix src/ tests/ 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(uv run *)",
      "Bash(git *)",
      "Bash(mkdir *)",
      "Bash(touch *)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  }
}
